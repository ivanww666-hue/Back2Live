{
    "_comment": "仅网格策略配置",
    "mode": "live",
    "interval": "1h",
    "initial_capital": 10000.0,
    "db_path": "market_data.db",
    "output_path": "results",
    "start_date": "2024-01-01",
    "end_date": "2026-01-20",
    "max_workers": 4,
    "binance": {
        "api_key": "${BINANCE_API_KEY}",
        "api_secret": "${BINANCE_API_SECRET}",
        "testnet": true
    },
    "strategy_mapping": {
        "grid_strategy": "GridStrategy",
        "slope_ma_strategy": "SlopeMAStrategy"
    },
    "strategies": [
        {
            "name": "ETH网格",
            "type": "grid_strategy",
            "enabled": true,
            "symbol": "ethusdt",
            "grid_low": 1700,
            "grid_high": 2600,
            "grid_count": 20,
            "position_per_grid_pct": 5.0,
            "stop_loss_pct": 8.0,
            "take_profit_pct": 6.0,
            "trailing_stop_pct": 4.0,
            "max_positions": 20
        }
    ]
}
